{
    "name": "homediary-api",
    "build": {
        "dockerfile": "Dockerfile",
        "context": ".",
        "args": {
            "HTTP_PROXY": "http://host.docker.internal:7890",
            "HTTPS_PROXY": "http://host.docker.internal:7890",
            "NO_PROXY": "localhost,127.0.0.1,.local,.internal"
        },
        "options": [
            "--add-host=host.docker.internal:host-gateway"
        ]
    },
    "runArgs": [
        "--network",
        "app32"
    ],
    "customizations": {
        "vscode": {
            "extensions": [
                "golang.go",
                "anthropic.claude-code",
                "redhat.vscode-yaml"
            ]
        }
    },
    "mounts": [
        // .devcontainer挂载
        "source=${localWorkspaceFolder:HOME}/.devcontainer/api,target=/workspace/.devcontainer/api,type=bind,consistency=cached",
        // Volume 持久化 home 目录（推荐）
        "source=homediary-api-home,target=/home/vscode,type=volume",
        // 可选：只读共享部分配置（不包含 hooks）
        "source=${localEnv:HOME}/.claude/settings,target=/home/vscode/.claude/settings,type=bind,consistency=cached",
        "source=${localEnv:HOME}/.claude/settings.json,target=/home/vscode/.claude/settings.json,type=bind,consistency=cached",
        "source=${localEnv:HOME}/.claude/agents,target=/home/vscode/.claude/agents,type=bind,consistency=cached",
        "source=${localEnv:HOME}/.claude/commands,target=/home/vscode/.claude/commands,type=bind,consistency=cached",
        "source=${localEnv:HOME}/.claude/hooks,target=/home/vscode/.claude/hooks,type=bind,consistency=cached",
        "source=${localEnv:HOME}/.claude/plugins,target=/home/vscode/.claude/plugins,type=bind,consistency=cached",
        "source=${localEnv:HOME}/.claude/package.json,target=/home/vscode/.claude/package.json,type=bind,consistency=cached",
        "source=${localEnv:HOME}/.claude/get-shit-done,target=/home/vscode/.claude/get-shit-done,type=bind,consistency=cached",
        "source=${localEnv:HOME}/.claude/gsd-file-manifest.json,target=/home/vscode/.claude/gsd-file-manifest.json,type=bind,consistency=cached"
    ],
    "workspaceMount": "source=${localWorkspaceFolder}/api,target=/workspace,type=bind",
    "workspaceFolder": "/workspace",
    "remoteUser": "vscode",

    // 项目特定的初始化（不包含权限和目录创建）
    "postCreateCommand": {
        "go-deps": "cd /workspace && go mod download || true",
        "verify": "echo '环境验证:' && go version && claude --version"
    },
    // 容器启动后执行
    "postStartCommand": "echo 'DevContainer 已就绪'"
}
