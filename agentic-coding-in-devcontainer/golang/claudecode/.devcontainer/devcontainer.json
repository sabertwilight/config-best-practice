{
    "name": "ccgodev",
    "image": "golang:1.25-trixie-cc",
    "runArgs": [
        "--add-host=host.docker.internal:host-gateway",
        "--network",
        "app32"
    ],
    "containerEnv": {
        "HTTP_PROXY": "http://host.docker.internal:7890",
        "HTTPS_PROXY": "http://host.docker.internal:7890",
        "NO_PROXY": "localhost,127.0.0.1"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "golang.go",
                "anthropic.claude-code",
                "redhat.vscode-yaml"
            ]
        }
    },
    "mounts": [
        "source=${localWorkspaceFolder:HOME}/.devcontainer,target=/workspace/.devcontainer,type=bind,consistency=cached",
        "source=ccgodev-cc,target=/home/vscode/.claude,type=volume",
        "source=${localEnv:HOME}/.claude/settings,target=/home/vscode/.claude/settings,type=bind,consistency=cached"
    ],
    "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind",
    "workspaceFolder": "/workspace",
    "remoteUser": "vscode",
    "postCreateCommand": "bash .devcontainer/post-create.sh"
}
