{
    "name": "ccpydev",
    "image": "ccpydevc:2.1.118-3.12-bullseye",
    "runArgs": [
        "--add-host=host.docker.internal:host-gateway",
        "--network",
        "app32"
    ],
    "containerEnv": {
        "HTTP_PROXY": "http://host.docker.internal:7890",
        "HTTPS_PROXY": "http://host.docker.internal:7890",
        "NO_PROXY": "localhost,127.0.0.1"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.debugpy",
                "ms-python.vscode-python-envs",
                "ms-python.flake8",
                "ms-python.black-formatter",
                "ms-python.vscode-pylance",
                "redhat.vscode-yaml",
                "anthropic.claude-code"
            ],
            "settings": {
                "python.defaultInterpreterPath": "/workspace/.venv/bin/python"
            }
        }
    },
    "mounts": [
        "source=${localWorkspaceFolder:HOME}/.devcontainer,target=/workspace/.devcontainer,type=bind,consistency=cached",
        "source=ccpydev-cc,target=/home/vscode/.claude,type=volume",
        "source=${localEnv:HOME}/.claude/settings,target=/home/vscode/.claude/settings,type=bind,consistency=cached"
    ],
    "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind",
    "workspaceFolder": "/workspace",
    "remoteUser": "vscode",
    "postCreateCommand": "bash .devcontainer/post-create.sh"
}
