{
    "name": "satmetainfo-api",
    "build": {
        "dockerfile": "Dockerfile",
        "context": "../../satmetaapi"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.debugpy",
                "ms-python.vscode-python-envs",
                "ms-python.flake8",
                "ms-python.black-formatter",
                "ms-python.vscode-pylance",
                "redhat.vscode-yaml",
                "moonshot-ai.kimi-code"
            ],
            "settings": {
                "python.defaultInterpreterPath": "/workspace/.venv/bin/python"
            }
        }
    },
    "mounts": [
        "source=${localWorkspaceFolder:HOME}/.devcontainer/satmetaapi,target=/workspace/.devcontainer/satmetaapi,type=bind,consistency=cached",
        "source=${localEnv:HOME}/.kimi,target=/home/vscode/.kimi,type=bind"
    ],
    "workspaceMount": "source=${localWorkspaceFolder}/satmetaapi,target=/workspace,type=bind",
    "workspaceFolder": "/workspace",
    "remoteUser": "vscode"
}
